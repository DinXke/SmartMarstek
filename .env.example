# SmartMarstek Standalone Deployment Configuration

# ── Home Assistant Integration ──────────────────────────────────────────────────
HA_URL=
HA_TOKEN=

# ── ENTSO-E API (electricity prices) ────────────────────────────────────────────
ENTSOE_API_KEY=
ENTSOE_COUNTRY=BE

# ── Timezone ────────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Brussels

# ── InfluxDB Configuration ──────────────────────────────────────────────────────
INFLUX_USERNAME=marstek
INFLUX_PASSWORD=marstek2024!
INFLUX_ORG=marstek
INFLUX_BUCKET=energy
INFLUX_ADMIN_TOKEN=marstek-influx-token-local

# ── Grafana Configuration ───────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost/grafana

# ── Logging ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
